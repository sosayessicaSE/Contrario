# Supabase (Auth + Postgres + Storage)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Drizzle / Postgres (use Supabase connection string: Project Settings > Database)
# `pnpm db:migrate` / `pnpm db:seed` load `.env` via dotenv (see drizzle.config.ts and scripts/seed.ts).
#
# If Postgres says "remaining connection slots are reserved for roles with the SUPERUSER attribute", the DB is at
# its connection limit. Fix: (1) use Supabase **Transaction pooler** URI (often port 6543, "Transaction" mode in
# the dashboard) for this app, not the direct `db.*:5432` session URL; (2) optionally lower `DATABASE_POOL_MAX`.
# If you see ETIMEDOUT to an IPv6 address on port 5432, try the pooler URI or `pnpm db:migrate` (IPv4-first DNS) — NOTES.md.
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
# DATABASE_POOL_MAX=3

# Server
NEXT_PUBLIC_APP_URL=http://localhost:3000

# LLM (optional; use MOCK_AI for dev without spend)
LLM_API_KEY=
LLM_API_BASE_URL=
SUMMARIZE_MODEL=gpt-4o-mini
MOCK_AI=0

# Logging
LOG_LEVEL=info

# Docker / Railway
PORT=3000
APPLY_RLS_ON_START=0

# Seed (scripts/seed.ts)
SEED_RESET=0
SEED_USER_PASSWORD=Password123!Seed
# SEED_USER_IDS=uuid1,uuid2,... (only if you are not using SUPABASE_SERVICE_ROLE_KEY)
