# Supabase (Auth + Postgres + Storage)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Drizzle / Postgres (use Supabase connection string: Project Settings > Database)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Server
NEXT_PUBLIC_APP_URL=http://localhost:3000

# LLM (optional; use MOCK_AI for dev without spend)
LLM_API_KEY=
LLM_API_BASE_URL=
SUMMARIZE_MODEL=gpt-4o-mini
MOCK_AI=0

# Logging
LOG_LEVEL=info

# Docker / Railway
PORT=3000
APPLY_RLS_ON_START=0

# Seed (scripts/seed.ts)
SEED_RESET=0
SEED_USER_PASSWORD=Password123!Seed
# SEED_USER_IDS=uuid1,uuid2,... (only if you are not using SUPABASE_SERVICE_ROLE_KEY)
